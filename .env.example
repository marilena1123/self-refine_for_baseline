# ── Required ────────────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# ── Optional overrides (all have defaults in config.py) ─────────────────────

# Model to use — any OpenRouter model ID. Examples:
#   openai/gpt-3.5-turbo          (default)
#   openai/gpt-4o
#   anthropic/claude-3-haiku
#   anthropic/claude-3.5-sonnet
#   meta-llama/llama-3-8b-instruct
#   mistralai/mistral-7b-instruct
# OPENROUTER_MODEL=openai/gpt-3.5-turbo

# Max self-refine iterations per sample (default: 4)
# MAX_ATTEMPTS=4

# Limit how many rows to process from the input file (default: all)
# N_SAMPLES=10
